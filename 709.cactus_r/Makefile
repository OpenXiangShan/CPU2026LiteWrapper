.PHONY: clean_preprocess_objs
clean_preprocess_objs:

refrate-cmp:
	@for f in cactus.out gxx.dl gxx.xl gxx.yl gxx.zl gxy.dl gxy.xl gxy.yl gxy.zl; do \
		$(call SPECDIFF, --abstol 1e-14 --reltol 1e-4, $(RUN_DIR)/$$f, data/refrate/output/$$f); \
	done
train-cmp:
	@for f in cactus.out gxx.dl gxx.xl gxx.yl gxx.zl gxy.dl gxy.xl gxy.yl gxy.zl; do \
		$(call SPECDIFF, --abstol 1e-14 --reltol 1e-4, $(RUN_DIR)/$$f, data/train/output/$$f); \
	done
test-cmp:
	@for f in cactus.out gxx.dl gxx.xl gxx.yl gxx.zl gxy.dl gxy.xl gxy.yl gxy.zl; do \
		$(call SPECDIFF, --abstol 1e-14 --reltol 1e-4, $(RUN_DIR)/$$f, data/test/output/$$f); \
	done
