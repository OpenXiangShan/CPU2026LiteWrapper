.PHONY: clean_preprocess_objs
clean_preprocess_objs:

refrate-cmp:
	@for f in queuenet-AllocDealloc-0.sca queuenet-CallCenter-0.sca queuenet-ForkJoin-0.sca queuenet-OneFifo-0.sca queuenet-ResourceAllocation-0.sca queuenet-Ring-0.sca queuenet-SmallCQN-0.sca queuenet-TandemFifos-0.sca queuenet-Terminal-0.sca randomMesh-General-0.sca randomMesh-General-1.sca randomMesh-General-2.sca; do \
		$(call SPECDIFF, --abstol 1e-9 --reltol 1e-7, $(RUN_DIR)/$$f, data/refrate/output/$$f); \
	done
train-cmp:
	@for f in General-0.sca General-1.sca General-2.sca General-3.sca OneFifo-#0.sca; do \
		$(call SPECDIFF, --abstol 1e-9 --reltol 1e-7, $(RUN_DIR)/$$f, data/train/output/$$f); \
	done
test-cmp:
	@for f in omnetpp.AllocDealloc-0.out omnetpp.OneFifo-0.out randomMesh-General-0.sca; do \
		$(call SPECDIFF, --abstol 1e-9 --reltol 1e-7, $(RUN_DIR)/$$f, data/test/output/$$f); \
	done
