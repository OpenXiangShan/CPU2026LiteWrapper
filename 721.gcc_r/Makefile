.PHONY: clean_preprocess_objs
clean_preprocess_objs:

refrate-cmp:
	@for f in gcc-pp.c.opts-O2_-fpic.s gcc-smaller.c.opts-O3_-fipa-pta.s ref32.c.opts-O3_-finline-limit_12000_-fno-tree-vrp.s; do \
		$(DIFF) $(RUN_DIR)/$$f data/refrate/output/$$f; \
	done
train-cmp:
	@for f in 200.c.opts-O2.s scilab.c.opts-O3.s train01.c.opts-O3_-finline-limit_50000.s; do \
		$(DIFF) $(RUN_DIR)/$$f data/train/output/$$f; \
	done
test-cmp:
	@for f in t1.c.opts-O3_-finline-limit_50000.s; do \
		$(DIFF) $(RUN_DIR)/$$f data/test/output/$$f; \
	done
