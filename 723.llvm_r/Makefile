refrate-cmp:
	@for f in codegen.bc.opts-S_-O3_-mcpu_pwr9.out transformsplus.bc.opts-S_-O3_-mcpu_pwr9.out; do \
		$(DIFF) $(RUN_DIR)/$$f data/refrate/output/$$f; \
	done
train-cmp:
	@for f in ELFObject.ll.opts-S_-O2_-inline-threshold_50000_-mcpu_pwr9.out train.ll.opts-S_-O3_-mcpu_pwr9.out; do \
		$(DIFF) $(RUN_DIR)/$$f data/train/output/$$f; \
	done
test-cmp:
	@for f in test.ll.opts-S_-O3_-mcpu_pwr9.out; do \
		$(DIFF) $(RUN_DIR)/$$f data/test/output/$$f; \
	done
