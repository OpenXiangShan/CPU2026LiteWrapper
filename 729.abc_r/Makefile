.PHONY: clean_preprocess_objs
clean_preprocess_objs:

refrate-cmp:
	@for f in beem6.out.aig des_system90.out mcml.out mem_ctrl.out.aig twoexact.out vga_lcd_miter.out.aig; do \
		$(call SPECDIFF, --obiwan, $(RUN_DIR)/$$f, data/refrate/output/$$f); \
	done
train-cmp:
	@for f in des_perf.out.aig sparcT1_out.blif ucsb152_out.blif; do \
		$(call SPECDIFF, --obiwan, $(RUN_DIR)/$$f, data/train/output/$$f); \
	done
test-cmp:
	@for f in riscv.out truthtable.out; do \
		$(call SPECDIFF, --obiwan, $(RUN_DIR)/$$f, data/test/output/$$f); \
	done
