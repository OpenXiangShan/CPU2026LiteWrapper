.PHONY: clean_preprocess_objs
clean_preprocess_objs:

# Build gem5stats tool for validation
GEM5STATS_SRC = src/compare/gem5stats.cpp
GEM5STATS_BIN = $(HOST_DIR)/gem5stats
$(GEM5STATS_BIN): $(GEM5STATS_SRC)
	@mkdir -p $(HOST_DIR)
	$(HOST_CXX) -O2 -o $@ $<

# Generate _stats.out from m5out/*.stats.txt using gem5stats
# Usage: $(call run_gem5stats,<name>)
# <name>.stats.txt in m5out → <name>_stats.out in run dir
define run_gem5stats
	$(GEM5STATS_BIN) $(RUN_DIR)/control.stat $(RUN_DIR)/m5out/$(1).stats.txt > $(RUN_DIR)/$(1)_stats.out
endef

refrate-cmp: $(GEM5STATS_BIN)
	$(call run_gem5stats,run_riscv_boot.py_o3_10_--max-ticks_10_000_000_000)
	$(call run_gem5stats,run_riscv_boot.py_timing_4_--max-ticks_20_000_000_000)
	$(call run_gem5stats,synthetic_traffic.py_LinearGenerator_21)
	$(call run_gem5stats,synthetic_traffic.py_LinearGenerator_74_--ruby)
	@for f in run_riscv_boot.py_o3_10_--max-ticks_10_000_000_000_stats.out run_riscv_boot.py_timing_4_--max-ticks_20_000_000_000_stats.out synthetic_traffic.py_LinearGenerator_21_stats.out synthetic_traffic.py_LinearGenerator_74_--ruby_stats.out; do \
		$(call SPECDIFF, --obiwan --nonansupport, $(RUN_DIR)/$$f, data/refrate/output/$$f); \
	done
train-cmp: $(GEM5STATS_BIN)
	$(call run_gem5stats,synthetic_traffic.py_LinearGenerator_100)
	@for f in synthetic_traffic.py_LinearGenerator_100_stats.out; do \
		$(call SPECDIFF, --obiwan --nonansupport, $(RUN_DIR)/$$f, data/train/output/$$f); \
	done
test-cmp: $(GEM5STATS_BIN)
	$(call run_gem5stats,synthetic_traffic.py_LinearGenerator_100)
	@for f in synthetic_traffic.py_LinearGenerator_100_stats.out; do \
		$(call SPECDIFF, --obiwan --nonansupport, $(RUN_DIR)/$$f, data/test/output/$$f); \
	done
