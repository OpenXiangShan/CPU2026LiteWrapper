.PHONY: clean_preprocess_objs
clean_preprocess_objs:

refrate-cmp:
	@for f in dctcp-example-fairness.dat dctcp-example-s1-r1-throughput.dat dctcp-example-s2-r2-throughput.dat dctcp-example-s3-r1-throughput.dat dctcp-example-t1-length.dat dctcp-example-t2-length.dat dctcp-example_3.out lena-radio-link-failure_2.out mobile-scenario.xml rlf_dl_thrput_2_eNB_ideal_rrc tcp-dynamic-pacing-cwnd.dat tcp-dynamic-pacing-ssthresh.dat tcp-pacing_1.out wifi-eht-network_5.out wifi-mixed-network_4.out; do \
		$(call SPECDIFF, --abstol 0.000001, $(RUN_DIR)/$$f, data/refrate/output/$$f); \
	done
train-cmp:
	@for f in wifi-mixed-network_0.out wifi-mixed-network_1.out; do \
		$(call SPECDIFF, --abstol 0.000001, $(RUN_DIR)/$$f, data/train/output/$$f); \
	done
test-cmp:
	@for f in tcp-dynamic-pacing-cwnd.dat tcp-dynamic-pacing-ssthresh.dat tcp-pacing_0.out wifi-mixed-network_1.out; do \
		$(call SPECDIFF, --abstol 0.000001, $(RUN_DIR)/$$f, data/test/output/$$f); \
	done
