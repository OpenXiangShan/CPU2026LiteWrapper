refrate-cmp:
	@for f in roms_benchmark2.log; do \
		$(call SPECDIFF, --abstol 1.0e-7 --reltol 1.0e-7, $(RUN_DIR)/$$f, data/refrate/output/$$f); \
	done
train-cmp:
	@for f in roms_benchmark1.log; do \
		$(call SPECDIFF, --abstol 2.0e-7 --reltol 1.0e-7, $(RUN_DIR)/$$f, data/train/output/$$f); \
	done
test-cmp:
	@for f in roms_benchmark0.log; do \
		$(call SPECDIFF, --abstol 1.0e-7 --reltol 1.0e-7, $(RUN_DIR)/$$f, data/test/output/$$f); \
	done
