	@for f in ArtificialSynchrony.sli.out cuba_stdp-11253-0.dat cuba_stdp-11254-0.dat cuba_stdp.sli.out spb_log_00.dat spike_recorder-6002-0.dat structural_plasticity_benchmark.sli.out voltmeter-Grid-0-129-0.dat voltmeter-Grid-1-129-0.dat voltmeter-Grid-2-129-0.dat voltmeter-Grid-3-129-0.dat voltmeter-Grid-4-129-0.dat voltmeter-Grid-5-129-0.dat voltmeter-Precise-0-129-0.dat voltmeter-Precise-1-129-0.dat voltmeter-Precise-2-129-0.dat voltmeter-Precise-3-129-0.dat voltmeter-Precise-4-129-0.dat voltmeter-Precise-5-129-0.dat; do \
		$(DIFF) $(RUN_DIR)/$$f data/refrate/output/$$f; \
	done
train-cmp:
	@for f in balancedneuron-2.sli.out cuba-4002-0.dat cuba-4003-0.dat cuba.sli.out cuba_ps-4002-0.dat cuba_ps-4003-0.dat cuba_ps.sli.out; do \
		$(DIFF) $(RUN_DIR)/$$f data/train/output/$$f; \
	done
test-cmp:
	@for f in BrodyHopfield.sli.out balancedneuron.sli.out spike_recorder-0003-0.dat; do \
		$(DIFF) $(RUN_DIR)/$$f data/test/output/$$f; \
	done
