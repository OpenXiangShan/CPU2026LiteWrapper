+ * doubling wall-clock time. Aligning the function entry to 512 B and pushing
+ * the loop body 0x100 bytes further inside lands every hot load in the
+ * "good" 256 B band [0x1C0 .. 0xBF] (mod 512). The NOP sled executes once
+ * per call (not per cell), so the runtime cost is negligible.
+ */
+__attribute__((aligned(512)))
+#endif
